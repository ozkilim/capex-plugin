{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__plugin_capex_code__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/tracking-hook.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/tracking-hook.js"
          }
        ]
      }
    ]
  }
}
